{
  "name": "thread-weaver",
  "version": "0.1.0",
  "description": "Type-safe Web Worker RPC — call worker methods as async functions",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./worker": {
      "import": {
        "types": "./dist/worker.d.ts",
        "default": "./dist/worker.js"
      },
      "require": {
        "types": "./dist/worker.d.cts",
        "default": "./dist/worker.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --noEmit && tsup",
    "dev": "tsup --watch",
    "benchmark": "vite example/benchmark",
    "example:transferables": "vite example/transferables",
    "test": "vitest run --project unit",
    "test:e2e": "vitest run --project e2e",
    "test:all": "vitest run",
    "test:watch": "vitest --project unit",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "worker",
    "web-worker",
    "rpc",
    "proxy",
    "typescript",
    "async"
  ],
  "license": "MIT",
  "devDependencies": {
    "@vitest/browser": "^4.1.0",
    "@vitest/browser-playwright": "^4.1.0",
    "playwright": "^1.58.2",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
